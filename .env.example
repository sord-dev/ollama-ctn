# Ollama Configuration
OLLAMA_NUM_PARALLEL=1     # concurrent requests
OLLAMA_MAX_LOADED_MODELS=1  # how many models stay in memory
OLLAMA_KEEP_ALIVE=5m      # how long model stays loaded after last request

# Network Configuration
OLLAMA_PORT=11435         # external port (avoid conflict with existing instance)

# Resource Limits
MEMORY_LIMIT=8g           # maximum memory usage
CPU_LIMIT=4               # maximum CPU cores

# Logging
LOG_MAX_SIZE=10m          # maximum log file size
LOG_MAX_FILES=3           # number of log files to keep